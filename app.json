{
  "expo": {
    "name": "Hoard",
    "slug": "hoard",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "hoard",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon/icon.png",
    "splash": {
      "image": "./assets/icon/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070403"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chronorixun.hoard",
      "buildNumber": "1",
      "deploymentTarget": "14.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E7A1.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.chronorixun.hoard",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/adaptive-icon.png",
        "backgroundColor": "#0a0403"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
