{
  "expo": {
    "name": "D2 Mule Tracker",
    "slug": "d2-mule-tracker",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "d2muletracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chronorixun.d2muletracker"
    },
    "android": {
      "package": "com.chronorixun.d2muletracker",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
